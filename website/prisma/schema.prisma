generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Attachment {
  id          String      @id
  messageId   String
  filename    String
  mimeType    String
  fileSize    Int
  fileData    String
  storageType String      @default("base64")
  createdAt   DateTime    @default(now())
  ChatMessage ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model ChatMessage {
  id             String       @id
  conversationId String
  role           String
  content        String
  createdAt      DateTime     @default(now())
  Attachment     Attachment[]
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Conversation {
  id          String        @id
  userId      String
  title       String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  ChatMessage ChatMessage[]
  User        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model License {
  id              String    @id
  code            String    @unique
  durationDays    Int       @default(30)
  isUsed          Boolean   @default(false)
  usedBy          String?
  usedAt          DateTime?
  createdBy       String?
  description     String?
  createdAt       DateTime  @default(now())
  claimedByUserId String?

  @@index([claimedByUserId])
  @@index([isUsed])
  @@index([code])
}

model Order {
  id                    String    @id
  userId                String?
  orderNumber           String    @unique
  status                String    @default("pending")
  customerName          String
  customerEmail         String
  customerPhone         String
  pickupPoint           String    @default("")
  pickupPointAddress    String    @default("")
  stripePaymentIntentId String?   @unique
  p24SessionId          String?   @unique
  paymentProvider       String    @default("stripe")
  amount                Int
  currency              String    @default("pln")
  trackingNumber        String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime
  paidAt                DateTime?
  shippedAt             DateTime?
  deliveredAt           DateTime?
  invoiceSentAt         DateTime?
  invoiceFilename       String?
  User                  User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([customerEmail])
  @@index([orderNumber])
  @@index([userId])
  @@index([p24SessionId])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                     String    @id
  userId                 String    @unique
  status                 String    @default("trial")
  trialEndsAt            DateTime
  trialDays              Int       @default(1)
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  plan                   String    @default("ai_chat")
  pricePerMonth          Int       @default(2900)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime
  cancelledAt            DateTime?
  User                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeSubscriptionId])
  @@index([stripeCustomerId])
  @@index([userId])
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String?
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  Account       Account[]
  Conversation  Conversation[]
  Order         Order[]
  Session       Session[]
  Subscription  Subscription?
  Device        Device[]
  DeviceSolve   DeviceSolve[]
  Note          Note[]
  Test          Test[]
}

model Device {
  id              String        @id @default(cuid())
  deviceId        String        @unique
  userId          String?
  User            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  licenseCode     String?
  unlockCode      String?
  firstSeen       DateTime      @default(now())
  lastSeen        DateTime      @default(now())
  requestCount    Int           @default(0)
  firmwareVersion String?
  lastIp          String?
  deviceToken     String?       @unique
  Solves          DeviceSolve[]

  @@index([deviceId])
  @@index([userId])
  @@index([licenseCode])
}

model DeviceSolve {
  id          String   @id @default(cuid())
  deviceId    String
  Device      Device   @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)
  licenseCode String?
  userId      String?
  User        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  mode        String?
  question    String
  answer      String
  createdAt   DateTime @default(now())

  @@index([deviceId, createdAt])
  @@index([licenseCode])
  @@index([userId, createdAt])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("")
  content   String   @default("")
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, position])
}

model Test {
  id        String   @id @default(cuid())
  userId    String
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("")
  content   String   @default("")
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, position])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Visit {
  id        String   @id
  ipHash    String
  userAgent String?
  referer   String?
  page      String   @default("/")
  createdAt DateTime @default(now())

  @@index([ipHash])
  @@index([createdAt])
}
