#include <Arduino.h>
#include <Wire.h>
#include <Adafruit_MCP23X17.h>
#include <U8g2lib.h>
#include <SPI.h>

Adafruit_MCP23X17 mcp;
// CLK i MOSI zamienione na PCB — używamy SW SPI żeby móc zamienić piny
U8G2_SSD1322_NHD_256X64_F_4W_SW_SPI u8g2(U8G2_R0, /*clock=*/23, /*data=*/18, /*cs=*/15, /*dc=*/2, /*reset=*/4);

void setup() {
    Serial.begin(115200);

    Wire.begin(21, 22);
    mcp.begin_I2C(0x20);

    // Boost OFF - zewnetrzny zasilacz 14.7V na FFC pin 3/4
    mcp.pinMode(7, OUTPUT);
    mcp.digitalWrite(7, LOW);
    delay(100);

    u8g2.begin();
    Serial.println("OLED init OK");

    u8g2.clearBuffer();
    u8g2.setFont(u8g2_font_10x20_tf);
    u8g2.drawStr(60, 40, "KalkMate!");
    u8g2.sendBuffer();
    Serial.println("wyslano");
}

void loop() {
    delay(1000);
    u8g2.clearBuffer();
    u8g2.setFont(u8g2_font_10x20_tf);
    u8g2.drawStr(60, 40, "KalkMate!");
    u8g2.sendBuffer();
}
