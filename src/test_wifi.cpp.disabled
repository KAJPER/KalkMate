// test_wifi.cpp.disabled
// WiFi + HTTP connectivity test for KalkMate (ESP32-WROVER-E)
// Extension .disabled prevents this file from being compiled with main.cpp.
// To run: temporarily rename to test_wifi.cpp and comment out/rename main.cpp.

#include <Arduino.h>
#include <WiFi.h>
#include <HTTPClient.h>
#include "config.h"

void setup() {
    Serial.begin(115200);
    delay(500);

    Serial.println("=== WiFi TEST ===");

    // --- Connect ---
    WiFi.mode(WIFI_STA);
    WiFi.begin(WIFI_SSID, WIFI_PASS);

    const unsigned long TIMEOUT_MS = 15000;
    unsigned long start = millis();
    bool connected = false;

    while (millis() - start < TIMEOUT_MS) {
        if (WiFi.status() == WL_CONNECTED) {
            connected = true;
            break;
        }
        Serial.print(".");
        delay(250);
    }
    Serial.println();

    if (!connected) {
        Serial.println("FAIL: WiFi timeout");
        // Halt
        while (true) { delay(1000); }
    }

    Serial.print("PASS: WiFi connected, IP: ");
    Serial.println(WiFi.localIP().toString());

    // --- RSSI ---
    Serial.print("RSSI: ");
    Serial.print(WiFi.RSSI());
    Serial.println(" dBm");

    // --- HTTP GET ---
    String url = String(API_BASE_URL) + "/ping";
    Serial.print("HTTP GET -> ");
    Serial.println(url);

    HTTPClient http;
    http.begin(url);
    int httpCode = http.GET();

    Serial.print("HTTP code: ");
    Serial.println(httpCode);

    if (httpCode > 0) {
        String body = http.getString();
        // Print first 200 characters of the response body
        if (body.length() > 200) {
            body = body.substring(0, 200);
        }
        Serial.print("Response (first 200 chars): ");
        Serial.println(body);
        Serial.println("PASS: HTTP GET succeeded");
    } else {
        Serial.print("FAIL: HTTP GET error: ");
        Serial.println(http.errorToString(httpCode));
    }

    http.end();

    // --- Cleanup ---
    WiFi.disconnect(true);
    WiFi.mode(WIFI_OFF);

    Serial.println("=== TEST DONE ===");
}

void loop() {
    // Empty – test runs once in setup()
}
